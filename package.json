{
  "name": "recordair-design-system",
  "version": "0.2.4",
  "private": true,
  "description": "Design system React extrait de Record'air sans couplage au produit.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "storybook": "npm run build && storybook dev -p 6006 --no-open",
    "build-storybook": "npm run build && storybook build",
    "pack:dry-run": "npm pack --cache .npm-cache --workspaces --dry-run",
    "release:publish": "bash scripts/publish-packages.sh"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.0.0",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^10.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
